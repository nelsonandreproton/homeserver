# homeserver/.env
#
# Compose-level variables — used for interpolation in docker-compose.yml.
# Each service loads its own secrets from its repo's .env file.
#
# Copy to .env and fill in the values:
#   cp .env.example .env

# ── Caddy HTTPS ────────────────────────────────────────────────────────────────
# Your server's public IP with dashes, followed by .sslip.io
# e.g. for IP 1.2.3.4 → CADDY_HOST=1-2-3-4.sslip.io
CADDY_HOST=YOUR-IP-WITH-DASHES.sslip.io

# ── Docker socket access (for /server_status Docker container list) ───────────
# GID of the docker group on the host: getent group docker | cut -d: -f3
DOCKER_GID=999

# ── CNCSearch embeddings (passed to GarminBot for /canticos) ──────────────────
# "jina" (default, free tier at jina.ai — 1M tokens/month) or "local"
EMBEDDING_PROVIDER=jina
JINA_API_KEY=jina_...
